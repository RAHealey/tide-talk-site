{
  "name": "tide-talk",
  "description": "The Terrace — a bold supporters'-culture theme for Tide Talk, independent Rhode Island FC coverage.",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Tide Talk",
    "email": "hello@tidetalkri.com",
    "url": "https://tidetalkri.com"
  },
  "keywords": [
    "ghost-theme",
    "sports",
    "soccer"
  ],
  "config": {
    "posts_per_page": 12,
    "image_sizes": {
      "xs": { "width": 100 },
      "s": { "width": 400 },
      "m": { "width": 750 },
      "l": { "width": 1200 },
      "xl": { "width": 1600 }
    },
    "card_assets": true,
    "custom": {
      "footer_tagline": {
        "type": "text",
        "default": "Tide Talk was founded under the key principle of creating content for the fans, by the fans."
      },
      "ticker_tagline": {
        "type": "text",
        "default": "Content by fans, for fans"
      },
      "newsletter_url": {
        "type": "text",
        "description": "Your Beehiiv subscribe page URL. Used by the 'Join the Tide' form when Ghost members are off."
      },
      "apple_podcasts_url": {
        "type": "text",
        "description": "Apple Podcasts show URL (footer Listen)."
      },
      "spotify_url": {
        "type": "text",
        "default": "https://open.spotify.com/show/0P3cNx3nSFLcu6Xr095I4G",
        "description": "Spotify podcast show URL (footer Listen + socials)."
      },
      "youtube_url": {
        "type": "text",
        "default": "https://www.youtube.com/@TideTalkRI",
        "description": "YouTube channel URL (footer Listen + socials)."
      },
      "instagram_url": {
        "type": "text",
        "default": "https://www.instagram.com/tidetalkri/",
        "description": "Instagram profile URL (footer socials)."
      },
      "x_url": {
        "type": "text",
        "default": "https://twitter.com/TideTalkRI",
        "description": "X / Twitter profile URL (footer socials)."
      },
      "facebook_url": {
        "type": "text",
        "default": "https://www.facebook.com/profile.php?id=61556290666031",
        "description": "Facebook page URL (footer socials)."
      },
      "store_url": {
        "type": "text",
        "description": "Merch store URL (footer More)."
      }
    }
  }
}
