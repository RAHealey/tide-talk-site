{{! "Join the Tide" newsletter CTA. }}
{{! - If Ghost members are enabled, uses the native Portal signup form. }}
{{! - Otherwise, if @custom.newsletter_url (your Beehiiv subscribe page) is set, the }}
{{!   form hands the email to Beehiiv in a new tab where the subscriber confirms. }}
{{! - If neither is configured, no signup input is shown (rather than a dead form). }}
<section class="join" id="newsletter">
    <div class="wrap">
        <div class="jcard">
            <div class="ht"></div>
            <div class="inner">
                <div>
                    <h2>Join the Tide</h2>
                    <p>Reactions, ratings and roster chaos &mdash; free in your inbox every week. From the fans who never miss a kick.</p>
                </div>
                {{#if @site.members_enabled}}
                    <form data-members-form="subscribe">
                        <div class="row">
                            <input data-members-email type="email" placeholder="you@email.com" aria-label="Email" required>
                            <button type="submit">Sign Up</button>
                        </div>
                        <span class="fine">No spam. Unsubscribe anytime.</span>
                    </form>
                {{else if @custom.newsletter_url}}
                    {{! Beehiiv: submitting opens the subscribe page with the email prefilled for confirmation. }}
                    <form action="{{@custom.newsletter_url}}" method="get" target="_blank" rel="noopener">
                        <div class="row">
                            <input type="email" name="email" placeholder="you@email.com" aria-label="Email" required>
                            <button type="submit">Sign Up</button>
                        </div>
                        <span class="fine">Powered by Beehiiv &middot; Unsubscribe anytime</span>
                    </form>
                {{/if}}
            </div>
        </div>
    </div>
</section>
