{{!-- Top scarf ticker: on the homepage, latest podcast episode + auto-updated match
line (from the hidden match-ticker page, written ~every 2h by tools/update-ticker.mjs
from ESPN). Other pages show the static tagline. Get helpers are siblings, not nested. --}}
<div class="scarf">
    <div class="track">
        {{#is "home"}}
            {{#get "posts" filter="tag:podcast" limit="1" as |ep|}}{{#foreach ep}}<span class="star">&#10022;</span><span><b>New Episode &mdash; {{title}}</b></span>{{/foreach}}{{/get}}{{#get "pages" filter="slug:match-ticker" limit="1" as |md|}}{{#foreach md}}<span class="t">&#9670;</span><span><b>{{excerpt}}</b></span>{{/foreach}}{{/get}}
            {{#get "posts" filter="tag:podcast" limit="1" as |ep|}}{{#foreach ep}}<span class="star">&#10022;</span><span><b>New Episode &mdash; {{title}}</b></span>{{/foreach}}{{/get}}{{#get "pages" filter="slug:match-ticker" limit="1" as |md|}}{{#foreach md}}<span class="t">&#9670;</span><span><b>{{excerpt}}</b></span>{{/foreach}}{{/get}}
        {{else}}
            <span class="star">&#10022;</span><span><b>{{@custom.ticker_tagline}}</b></span><span class="t">&#9670;</span><span><b>{{@site.title}}</b></span>
            <span class="star">&#10022;</span><span><b>{{@custom.ticker_tagline}}</b></span><span class="t">&#9670;</span><span><b>{{@site.title}}</b></span>
        {{/is}}
    </div>
</div>
