{{!-- Top scarf ticker: always leads with "UP THE TIDE!"; on the homepage it also
scrolls the latest podcast episode + auto-updated match line (from the hidden
match-ticker page). Other pages show the tagline. Get helpers stay siblings, not nested. --}}
<div class="scarf">
    <div class="track">
        {{#is "home"}}
            <span class="star">&#10022;</span><span class="cry"><b>UP THE TIDE!</b></span>{{#get "posts" filter="tag:podcast" limit="1" as |ep|}}{{#foreach ep}}<span class="t">&#9670;</span><span><b>New Episode &mdash; {{title}}</b></span>{{/foreach}}{{/get}}{{#get "pages" filter="slug:match-ticker" limit="1" as |md|}}{{#foreach md}}<span class="t">&#9670;</span><span><b>{{excerpt}}</b></span>{{/foreach}}{{/get}}
            <span class="star">&#10022;</span><span class="cry"><b>UP THE TIDE!</b></span>{{#get "posts" filter="tag:podcast" limit="1" as |ep|}}{{#foreach ep}}<span class="t">&#9670;</span><span><b>New Episode &mdash; {{title}}</b></span>{{/foreach}}{{/get}}{{#get "pages" filter="slug:match-ticker" limit="1" as |md|}}{{#foreach md}}<span class="t">&#9670;</span><span><b>{{excerpt}}</b></span>{{/foreach}}{{/get}}
        {{else}}
            <span class="star">&#10022;</span><span class="cry"><b>UP THE TIDE!</b></span><span class="t">&#9670;</span><span><b>{{@custom.ticker_tagline}}</b></span><span class="t">&#9670;</span><span><b>{{@site.title}}</b></span>
            <span class="star">&#10022;</span><span class="cry"><b>UP THE TIDE!</b></span><span class="t">&#9670;</span><span><b>{{@custom.ticker_tagline}}</b></span><span class="t">&#9670;</span><span><b>{{@site.title}}</b></span>
        {{/is}}
    </div>
</div>
